# Copy this file to compose/.env and fill in real values.
# Do not commit a real .env file.
#
# These variables are read by compose/docker-compose.yml.

# --- Ollama (active in SPEC-004) ---
# Localhost port the Ollama API is published on.
OLLAMA_PORT=11434

# --- Postgres (disabled — not deployed yet) ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# --- Prediction API (commented stub until the service exists) ---
PREDICTION_API_HOST=
PREDICTION_API_PORT=

# --- Learning Engine (commented stub until the service exists) ---
LEARNING_ENGINE_HOST=
LEARNING_ENGINE_PORT=

# --- Discord Control (commented stub until the service exists) ---
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
