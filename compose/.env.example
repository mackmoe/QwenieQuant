# Copy this file to compose/.env and fill in real values.
# Do not commit a real .env file.
#
# These variables are read by compose/docker-compose.yml.

# --- Ollama (active in SPEC-004) ---
# Localhost port the Ollama API is published on.
OLLAMA_PORT=11434

# --- SearXNG (active in SPEC-005) ---
# No variables needed. SearXNG has no published host port (internal-only,
# reachable as http://searxng:8080 from other containers on the
# `internal` network) and its configuration lives in
# config/searxng/settings.yml, not in environment variables.

# --- Postgres (active in SPEC-006) ---
# Internal-only — no published host port. Reachable from other
# containers on the `internal` network as postgres:5432.
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# --- Prediction API (active in SPEC-007) ---
# Localhost port the Prediction API is published on.
PREDICTION_API_PORT=8000

# Ollama model configuration (read by prediction-api at runtime).
OLLAMA_MODEL=qwen3:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Learning Engine (active in SPEC-009) ---
# Localhost port the Learning Engine is published on.
LEARNING_ENGINE_PORT=8001

# --- Reflection Engine (active in SPEC-010) ---
# Localhost port the Reflection Engine is published on.
REFLECTION_ENGINE_PORT=8002

# --- Discord Control (active in SPEC-011) ---
# Discord bot token from the Discord Developer Portal.
DISCORD_BOT_TOKEN=
# ID of the Discord server (guild) where slash commands are registered.
DISCORD_GUILD_ID=
# Comma-separated Discord user IDs allowed to run commands.
# Example: ALLOWED_USER_IDS=123456789012345678,987654321098765432
ALLOWED_USER_IDS=

# --- Kalshi Connector (active in SPEC-012) ---
# Localhost port the Kalshi Connector is published on.
KALSHI_CONNECTOR_PORT=8003
# Kalshi API key from the Kalshi Developer Portal.
KALSHI_API_KEY=
# RSA private key PEM content (newlines escaped as \n for single-line env var).
# Alternatively, set KALSHI_PRIVATE_KEY_PATH to a file path.
KALSHI_PRIVATE_KEY=
# "demo" connects to demo-api.kalshi.co; "production" connects to trading-api.kalshi.com.
KALSHI_ENVIRONMENT=demo

# --- Risk Manager (active in SPEC-013) ---
# Localhost port the Risk Manager is published on.
RISK_MANAGER_PORT=8004
# Minimum prediction confidence (0.0–1.0) required to approve a trade.
MIN_CONFIDENCE=0.60
# Minimum expected value required to approve a trade.
MIN_EXPECTED_VALUE=0.01
# Minimum edge (probability advantage) required to approve a trade.
MIN_EDGE=0.05
# Maximum percent of account balance to risk on a single trade.
MAX_POSITION_PERCENT=5.0
# Maximum number of simultaneously open positions.
MAX_OPEN_POSITIONS=10
# Maximum total trade exposure approved per day, in cents (10000 = $100.00).
MAX_DAILY_LOSS=10000
# Maximum consecutive denied evaluations before blocking new trades.
MAX_CONSECUTIVE_LOSSES=5
# Set to false to allow real trade approvals. Default true for safety.
DRY_RUN=true
